# eclassiqnum Environment Variables
# Add ALL of these to Vercel → Settings → Environment Variables

# ─── DATABASE ────────────────────────────────────────────────
# Supabase → Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ─── SECURITY ────────────────────────────────────────────────
# Any random 32-char string → generate at: https://generate-secret.vercel.app/32
JWT_SECRET=your_random_secret_here

# ─── HERO SMS ────────────────────────────────────────────────
# hero-sms.com → Login → Profile → API Key
HERO_SMS_API_KEY=your_hero_sms_api_key

# ─── FLUTTERWAVE ─────────────────────────────────────────────
# dashboard.flutterwave.com → Settings → API Keys
FLW_SECRET_KEY=FLWSECK-your_secret_key
VITE_FLW_PUBLIC_KEY=FLWPUBK-your_public_key
# dashboard.flutterwave.com → Settings → Webhooks → Secret Hash
FLW_WEBHOOK_HASH=your_webhook_secret_hash

# ─── NOWPAYMENTS (Crypto) ────────────────────────────────────
# nowpayments.io → Store Settings → API Keys
NOWPAYMENTS_API_KEY=your_nowpayments_api_key

# ─── APP URL ─────────────────────────────────────────────────
APP_URL=https://eclassiqnum.vercel.app
